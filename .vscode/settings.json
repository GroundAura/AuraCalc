{
	//"flake8.args": ["--ignore=E251,E265,E266,E301,E302,E303,E501,W191"],
	"flake8.enabled": true,
	"flake8.severity": {
		"E": "Warning",
		"F": "Error",
		"I": "Information",
		"W": "Warning"
